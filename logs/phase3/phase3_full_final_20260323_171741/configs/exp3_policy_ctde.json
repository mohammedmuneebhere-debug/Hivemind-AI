{
  "environment": {
    "mode": "mock",
    "n_agents": 2,
    "local_state_dim": 4,
    "global_state_dim": 8,
    "action_dim": 2,
    "target_radius": 0.6,
    "target_radius_min": 0.25,
    "target_radius_max": 0.9,
    "collision_distance": 0.15,
    "max_steps": 200,
    "dt": 0.1,
    "accel_scale": 2.0
  },
  "reward": {
    "step_penalty": 0.001,
    "collision_penalty": 2.0,
    "task_completed_bonus": 20.0,
    "progress_scale": 1.0,
    "per_agent_target_bonus": 1.0
  },
  "training": {
    "algo": "ppo",
    "total_timesteps": 100000,
    "seed": 42,
    "save_path": "models/exp3_policy_ctde.zip",
    "tensorboard_log": "logs/tb",
    "policy": "ctde",
    "wandb": {
      "enabled": false,
      "project": "hivemind-ai",
      "name": "ppo-mock"
    }
  },
  "ppo": {
    "learning_rate": 0.0003,
    "n_steps": 1024,
    "batch_size": 256,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "ent_coef": 0.0,
    "vf_coef": 0.5,
    "max_grad_norm": 0.5,
    "clip_range": 0.2
  },
  "sac": {
    "learning_rate": 0.0003,
    "buffer_size": 1000000,
    "batch_size": 256,
    "gamma": 0.99,
    "tau": 0.005,
    "train_freq": 1,
    "gradient_steps": 1
  }
}